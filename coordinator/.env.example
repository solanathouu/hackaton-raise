# Copie en .env et remplis les clés. NE JAMAIS committer .env.
# Clés = serveur uniquement (jamais côté client).

# --- Crusoe Managed Inference (cerveau LLM, OpenAI-compatible) ---
# ⚠ Clé souvent avec des $ → toujours SINGLE QUOTES : CRUSOE_API_KEY='...'
CRUSOE_API_KEY=
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1
# Modèles AUTORISÉS uniquement (liste stricte) — benchmark : node scripts/compare-models.js
#   deepseek-ai/Deepseek-V4-Flash (⭐ ~3.8s, JSON fiable, primary recommandé)
#   google/gemma-4-31b-it (~4s, fallback recommandé)
#   nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B (~6s)
#   nvidia/NVIDIA-Nemotron-3-Ultra-550B (~11s, qualité max)
#   moonshotai/Kimi-K2.6 (timeout → éviter)
CRUSOE_MODEL=deepseek-ai/Deepseek-V4-Flash
CRUSOE_MODEL_FALLBACK=google/gemma-4-31b-it

# --- Gradium (voix : STT / TTS / S2S). Coupon RAISE-2026 = +100k crédits ---
# Auth = header x-api-key (PAS Bearer). Base REST réelle : https://api.gradium.ai/api
GRADIUM_API_KEY=
GRADIUM_BASE_URL=https://api.gradium.ai/api
# Gradium choisit la langue TTS via le voice_id (pas "default" — voir docs.gradium.ai/guides/voices).
GRADIUM_VOICE_FR=b35yykvVppLXyw_l
GRADIUM_VOICE_EN=YTpq7expH9539ERJ
GRADIUM_VOICE_ES=xu7iJ_fn2ElcWp2s

# --- Coordinateur ---
PORT=3000
# true = fixtures data/mock-fixtures.json (crusoe+gradium mockés). false = vraies API.
USE_MOCKS=true
# Mock par intégration (surcharge USE_MOCKS) : cerveau réel + voix mockée, ou l'inverse.
# MOCK_CRUSOE=false
# MOCK_GRADIUM=false
# Timeout d'accusé avant re-route (ms)
ACK_TIMEOUT_MS=15000
# Certs HTTPS (généré par npm run certs). Vide = HTTP (micro bloqué sur mobile !).
TLS_CERT=certs/cert.pem
TLS_KEY=certs/key.pem
