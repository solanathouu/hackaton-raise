# Copie en .env et remplis les clés. NE JAMAIS committer .env.
# Clés = serveur uniquement (jamais côté client).

# --- Crusoe Managed Inference (cerveau LLM, OpenAI-compatible) ---
CRUSOE_API_KEY=
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1
CRUSOE_MODEL=openai/gpt-oss-120b
CRUSOE_MODEL_FALLBACK=meta-llama/Llama-3.3-70B-Instruct

# --- Gradium (voix : STT / TTS / S2S). Coupon RAISE-2026 = +100k crédits ---
# Auth = header x-api-key (PAS Bearer). Base REST réelle : https://api.gradium.ai/api
GRADIUM_API_KEY=
GRADIUM_BASE_URL=https://api.gradium.ai/api
# Gradium choisit la langue TTS via le voice_id -> une voix par langue (récupérer les IDs dans le dashboard).
GRADIUM_VOICE_FR=default
GRADIUM_VOICE_EN=default
GRADIUM_VOICE_ES=default

# --- Coordinateur ---
PORT=3000
# true = fixtures data/mock-fixtures.json (crusoe+gradium mockés). false = vraies API.
USE_MOCKS=true
# Timeout d'accusé avant re-route (ms)
ACK_TIMEOUT_MS=15000
# Certs HTTPS (généré par npm run certs). Vide = HTTP (micro bloqué sur mobile !).
TLS_CERT=certs/cert.pem
TLS_KEY=certs/key.pem
