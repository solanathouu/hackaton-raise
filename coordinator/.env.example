# Copie en .env et remplis les clés. NE JAMAIS committer .env.
# Clés = serveur uniquement (jamais côté client).

# --- Crusoe Managed Inference (cerveau LLM, OpenAI-compatible) ---
# ⚠ Clé souvent avec des $ → toujours SINGLE QUOTES : CRUSOE_API_KEY='...'
CRUSOE_API_KEY=
CRUSOE_BASE_URL=https://api.inference.crusoecloud.com/v1
# Modèles AUTORISÉS uniquement (liste stricte) — benchmark : node scripts/compare-models.js
#   nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B (⭐ ~6s, primary recommandé)
#   deepseek-ai/Deepseek-V4-Flash (~3.8s, fallback JSON fiable FR/ES)
#   google/gemma-4-31b-it (~4s, alternative structured output)
#   nvidia/NVIDIA-Nemotron-3-Ultra-550B (~11s, qualité max)
#   moonshotai/Kimi-K2.6 (timeout → éviter)
CRUSOE_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B
CRUSOE_MODEL_FALLBACK=deepseek-ai/Deepseek-V4-Flash

# --- Gradium (voix : STT / TTS / S2S). Coupon RAISE-2026 = +100k crédits ---
# Auth = header x-api-key (PAS Bearer). Base REST réelle : https://api.gradium.ai/api
GRADIUM_API_KEY=
GRADIUM_BASE_URL=https://api.gradium.ai/api
# Gradium choisit la langue TTS via le voice_id -> une voix par langue.
# IDs de la librairie publique (docs.gradium.ai > Voices, vérifiés) — surchargeables :
#   fr Elise b35yykvVppLXyw_l · Leo axlOaUiFyOZhy4nv (masc)
#   en Emma  YTpq7expH9539ERJ
#   es Sergio xu7iJ_fn2ElcWp2s · Valentina B36pbz5_UoWn4BDl (fém, mx)
GRADIUM_VOICE_FR=b35yykvVppLXyw_l
GRADIUM_VOICE_EN=YTpq7expH9539ERJ
GRADIUM_VOICE_ES=xu7iJ_fn2ElcWp2s

# --- Fallback STT local (F9, optionnel) : whisper.cpp + ffmpeg ---
# ffmpeg dans le PATH (ou FFMPEG_BIN) = conversion webm/mp4 (MediaRecorder) -> wav.
# Binaire : https://github.com/ggml-org/whisper.cpp/releases (whisper-cli)
# Modèle multilingue : ggml-base.bin — https://huggingface.co/ggerganov/whisper.cpp
#FFMPEG_BIN=ffmpeg
#WHISPER_BIN=C:/tools/whisper/whisper-cli.exe
#WHISPER_MODEL=C:/tools/whisper/ggml-base.bin

# --- Capteur foule BLE (salle hackathon mappée sur une zone du site) ---
# pip install -r requirements-ble.txt  puis  npm run sensor:crowd  (serveur déjà lancé)
# CROWD_ZONE=Z5              zone mappée (défaut Z5 Place Centrale = la salle Neon Noir)
# BLE_BASELINE=80            baseline forcée pour ratio reproductible (count/baseline)
# DENSITY_RATIO_ALERT=1.5    au-delà -> coverage_warning si la zone n'a plus de marge staff
#COORD_URL=https://localhost:3000

# --- Coordinateur ---
PORT=3000
# true = fixtures data/mock-fixtures.json (crusoe+gradium mockés). false = vraies API.
USE_MOCKS=true
# Mock par intégration (surcharge USE_MOCKS) : cerveau réel + voix mockée, ou l'inverse.
# MOCK_CRUSOE=false
# MOCK_GRADIUM=false
# Timeout d'accusé avant re-route (ms)
ACK_TIMEOUT_MS=15000
# Log SQLite (node:sqlite natif). false = désactivé. Chemin surchargeable via SQLITE_PATH.
PERSIST=true
# Certs HTTPS (généré par npm run certs). Vide = HTTP (micro bloqué sur mobile !).
TLS_CERT=certs/cert.pem
TLS_KEY=certs/key.pem
